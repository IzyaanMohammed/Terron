{
  "name": "terron-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend/VerdaStruct-Builder/artifacts/api-server && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && cd frontend && npm install && cd ../backend/VerdaStruct-Builder/artifacts/api-server && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
